function refreshDungeonCache()
    dungeonCache = {}

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and DUNGEON_NPC_NAME_SET[obj.Name] then
            table.insert(dungeonCache, obj)
        end
    end
end

function removeFromList(list, item)
    for i = #list, 1, -1 do
        if list[i] == item then
            table.remove(list, i)
        end
    end
end

function addCachedModel(model)
    if not model:IsA("Model") then return end

    if NPC_NAME_SET[model.Name] then
        npcCache[model.Name] = npcCache[model.Name] or {}
        table.insert(npcCache[model.Name], model)
    elseif BOSS_NAMES[model.Name] then
        table.insert(bossCache, model)
    elseif DUNGEON_NPC_NAME_SET[model.Name] then
        table.insert(dungeonCache, model)
    end
end

function removeCachedModel(model)
    if not model:IsA("Model") then return end

    if NPC_NAME_SET[model.Name] and npcCache[model.Name] then
        removeFromList(npcCache[model.Name], model)
    elseif BOSS_NAMES[model.Name] then
        removeFromList(bossCache, model)
    elseif DUNGEON_NPC_NAME_SET[model.Name] then
        removeFromList(dungeonCache, model)
    end
end

function buildMobCache()
    if cacheReady then return end
    cacheReady = true

    for _, obj in ipairs(workspace:GetDescendants()) do
        addCachedModel(obj)
    end

    workspace.DescendantAdded:Connect(function(obj)
        addCachedModel(obj)
    end)

    workspace.DescendantRemoving:Connect(function(obj)
        removeCachedModel(obj)
    end)
end

