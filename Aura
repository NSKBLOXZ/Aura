function encodeUDim2(value)
    return {
        xs = value.X.Scale,
        xo = value.X.Offset,
        ys = value.Y.Scale,
        yo = value.Y.Offset
    }
end

function decodeUDim2(data)
    if type(data) ~= "table" then
        return nil
    end
    return UDim2.new(tonumber(data.xs) or 0, tonumber(data.xo) or 0, tonumber(data.ys) or 0, tonumber(data.yo) or 0)
end

