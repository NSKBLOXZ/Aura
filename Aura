function makeDropdown(parent, title, options, defaultValue, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 0, isMobile and 34 or 38)
    container.BackgroundTransparency = 1
    container.ClipsDescendants = false
    container.Parent = parent

    local main = makeButton(container, title .. ": " .. tostring(defaultValue or "None") .. " ▼", Color3.fromRGB(45, 125, 255))
    main.Size = UDim2.new(1, 0, 0, isMobile and 34 or 38)
    main.ZIndex = 40

    local drop = Instance.new("Frame")
    drop.Visible = false
    drop.Size = UDim2.new(1, 0, 0, 0)
    drop.Position = UDim2.new(0, 0, 0, isMobile and 38 or 42)
    drop.BackgroundColor3 = Color3.fromRGB(14, 20, 32)
    drop.BorderSizePixel = 0
    drop.ClipsDescendants = true
    drop.ZIndex = 50
    drop.Parent = container
    corner(drop, 10)
    stroke(drop, Color3.fromRGB(110, 180, 255), 0.55)

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 4
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ZIndex = 51
    scroll.Parent = drop
    padding(scroll, 5, 5, 5, 5)

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 4)
    layout.Parent = scroll
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)

    local opened = false
    local currentOptions = options or {}

    local function rebuild(newOptions)
        currentOptions = newOptions or currentOptions
        for _, child in ipairs(scroll:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        for _, option in ipairs(currentOptions) do
            local optionButton = makeButton(scroll, tostring(option), Color3.fromRGB(30, 40, 58), 28)
            optionButton.ZIndex = 52
            optionButton.MouseButton1Click:Connect(function()
                main.Text = title .. ": " .. tostring(option) .. " ▼"
                opened = false
                drop.Visible = false
                drop.Size = UDim2.new(1, 0, 0, 0)
                container.Size = UDim2.new(1, 0, 0, isMobile and 34 or 38)
                if callback then
                    callback(option)
                end
            end)
        end
    end

    main.MouseButton1Click:Connect(function()
        opened = not opened
        if opened then
            drop.Visible = true
            local height = math.clamp(#currentOptions * 32 + 12, 40, 180)
            container.Size = UDim2.new(1, 0, 0, (isMobile and 38 or 42) + height)
            drop:TweenSize(UDim2.new(1, 0, 0, height), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
        else
            drop:TweenSize(UDim2.new(1, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
            container.Size = UDim2.new(1, 0, 0, isMobile and 34 or 38)
            task.delay(0.12, function()
                if not opened then
                    drop.Visible = false
                end
            end)
        end
    end)

    rebuild(currentOptions)
    return {Container = container, Button = main, Refresh = rebuild}
end

