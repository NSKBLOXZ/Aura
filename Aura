    if priorityEnabled then return end
    priorityEnabled = true
    priorityThread = priorityThread + 1
    local myThread = priorityThread
    setStatus("Priority started")
    task.spawn(function()
        while priorityEnabled and myThread == priorityThread do
            local boss = getClosestBoss()
            if priorityBossEnabled and boss then
                selectedBoss = boss
                bossDropdown.Button.Text = "Select Boss: " .. boss.Name .. " ▼"
                bossSelectedLabel.Text = "Boss selected: " .. boss.Name
                stopAutoFarmNPC()
                startAutoFarmBoss()
            elseif priorityNPCEnabled then
                stopAutoFarmBoss()
                startAutoFarmNPC()
            end
            task.wait(1)
        end
    end)
