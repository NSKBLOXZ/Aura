    DUNGEON_NPC_NAMES = DUNGEON_LIST[selectedDungeon] or {}

    for _, dungeonNPCName in ipairs(DUNGEON_NPC_NAMES) do
        DUNGEON_NPC_NAME_SET[dungeonNPCName] = true
