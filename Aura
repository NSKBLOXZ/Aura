flyButton.MouseButton1Click:Connect(function()
	if flyEnabled then
		stopFly()
		setStatus("Status: fly desligado")
		return
	end

	stopFollowBoss()
	stopAutoFarmBoss()
	stopAutoFarmNPC()

	local root = getRoot()
	local humanoid = getHumanoid()

	flyEnabled = true
	flyThread += 1
	local myThread = flyThread

	humanoid.PlatformStand = true

	flyGyro = Instance.new("BodyGyro")
	flyGyro.P = 9e4
	flyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	flyGyro.CFrame = root.CFrame
	flyGyro.Parent = root

	flyVelocity = Instance.new("BodyVelocity")
	flyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	flyVelocity.Velocity = Vector3.zero
	flyVelocity.Parent = root

	task.spawn(function()
		while flyEnabled and myThread == flyThread do
			local camera = workspace.CurrentCamera
			local moveDirection = Vector3.zero
			local speed = 70

			if UserInputService:IsKeyDown(Enum.KeyCode.W) then
				moveDirection += camera.CFrame.LookVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then
				moveDirection -= camera.CFrame.LookVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then
				moveDirection -= camera.CFrame.RightVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then
				moveDirection += camera.CFrame.RightVector
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
				moveDirection += Vector3.new(0, 1, 0)
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
				moveDirection -= Vector3.new(0, 1, 0)
			end

			if moveDirection.Magnitude > 0 then
				moveDirection = moveDirection.Unit
			end

			if flyGyro and flyVelocity then
				flyGyro.CFrame = camera.CFrame
				flyVelocity.Velocity = moveDirection * speed
			end

			task.wait(0.03)
		end
	end)

	flyButton.Text = "Fly Livre: ON"
	setStatus("Status: fly ligado")
end)

