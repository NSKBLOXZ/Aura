applyTheme = function(themeName)
    currentTheme = THEMES[themeName] and themeName or "Cyber Blue"
    local t = THEMES[currentTheme]

    frame.BackgroundColor3 = t.Main
    topBar.BackgroundColor3 = t.Top
    sidebar.BackgroundColor3 = t.Sidebar
    statusBox.BackgroundColor3 = t.Card
    titleText.TextColor3 = t.AccentText
    statusLabel.TextColor3 = t.ON
    toggleButton.BackgroundColor3 = t.Button
    closeButton.BackgroundColor3 = t.OFF

    local function restyle(obj)
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("UIStroke") then
                child.Color = t.Stroke
            elseif child:IsA("TextLabel") then
                if child == titleText then
                    child.TextColor3 = t.AccentText
                elseif child == statusLabel then
                    child.TextColor3 = t.ON
                else
                    child.TextColor3 = t.Text
                end
            elseif child:IsA("TextBox") then
                child.BackgroundColor3 = t.Box
                child.TextColor3 = t.Text
                child.PlaceholderColor3 = t.AccentText
            elseif child:IsA("Frame") then
                if child ~= frame and child ~= topBar and child ~= sidebar and child ~= body and child ~= content then
                    if child.BackgroundTransparency < 1 then
                        child.BackgroundColor3 = t.Card
                    end
                end
            elseif child:IsA("TextButton") then
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
                if child ~= closeButton and child ~= toggleButton then
                    child.BackgroundColor3 = t.Button
                end
            end
        end
    end

    restyle(frame)
    restyle(toggleButton)

    updateAutoExecuteButton()
    updateCompactModeButton()
    updateMovementButtons()
    -- Evita erro de escopo: setActiveTab é declarado depois do applyTheme.
    -- A aba ativa será mantida ou definida no final do script.
    if themeDropdown and themeDropdown.Button then
        themeDropdown.Button.Text = "Theme: " .. currentTheme .. " ▼"
    end
    setStatus("Theme: " .. currentTheme)
end

function getConfigData()
    return {
        guiKey = guiToggleKey.Name,
        farmMode = farmMode,
        bossDistance = bossHeightBox and bossHeightBox.Text or "30",
        npcDistance = npcHeightBox and npcHeightBox.Text or "20",
        dungeonDistance = dungeonHeightBox and dungeonHeightBox.Text or "20",
        weapon = equipBox and equipBox.Text or "",
        autoExecute = autoExecuteEnabled,
        autoExecuteUrl = autoExecuteUrlBox and autoExecuteUrlBox.Text or "",
        theme = currentTheme,
        compactMode = compactModeEnabled,
        framePosition = encodeUDim2(frame.Position),
        manualNoClip = manualNoClipEnabled,
        speed = speedValue
    }
end

function saveConfig()
    if writefile then
        local success, encoded = pcall(function()
            return HttpService:JSONEncode(getConfigData())
        end)

        if success then
            writefile(CONFIG_FILE, encoded)
            setStatus("Config saved")
        else
            setStatus("Config save failed")
        end
    else
        setStatus("writefile not supported")
    end
end

function loadConfig()
    if not (isfile and readfile and isfile(CONFIG_FILE)) then
        setStatus("No config file")
        return
    end

    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)

    if not success or type(data) ~= "table" then
        setStatus("Config load failed")
        return
    end

    if data.guiKey and Enum.KeyCode[data.guiKey] then
        guiToggleKey = Enum.KeyCode[data.guiKey]
        keyBox.Text = data.guiKey
    end

    if data.farmMode then
        setFarmMode(data.farmMode)
        farmModeDropdown.Button.Text = "Farm Mode: " .. data.farmMode .. " ▼"
    end

    if data.bossDistance then
        bossHeightBox.Text = tostring(data.bossDistance)
    end

    if data.npcDistance then
        npcHeightBox.Text = tostring(data.npcDistance)
    end

    if data.dungeonDistance then
        dungeonHeightBox.Text = tostring(data.dungeonDistance)
    end

    if data.weapon then
        equipBox.Text = tostring(data.weapon)
    end

    if data.autoExecuteUrl then
        autoExecuteUrlBox.Text = tostring(data.autoExecuteUrl)
    end

    autoExecuteEnabled = data.autoExecute == true
    compactModeEnabled = data.compactMode == true
    savedFramePosition = decodeUDim2(data.framePosition)
    if data.speed then
        local loadedSpeed = tonumber(data.speed)
        if loadedSpeed then
            speedValue = math.clamp(loadedSpeed, 16, 200)
        end
    end

    manualNoClipEnabled = data.manualNoClip == true
    applySpeed()
    setManualNoClip(manualNoClipEnabled)

    updateAutoExecuteButton()
    updateCompactModeButton()
    updateMovementButtons()
    applyGuiLayout(true)

    if data.theme and THEMES[data.theme] then
        applyTheme(data.theme)
    else
        applyTheme(currentTheme)
    end

    setStatus("Config loaded")
end

