    orb.TextColor3 = T.text
    orb.Font = Enum.Font.GothamBlack
    orb.TextSize = 20
    orb.BorderSizePixel = 0
    orb.Parent = gui
    cr(orb, 999)
    st(orb, T.green, 0.25)

    local od, moved, ds, sp = false, false, nil, nil
    orb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            od = true
            moved = false
            ds = input.Position
            sp = orb.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End or input.UserInputState == Enum.UserInputState.Cancel then
                    od = false
                    task.delay(0.05, function() moved = false end)
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if od and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - ds
            if math.abs(delta.X) > 4 or math.abs(delta.Y) > 4 then moved = true end
            orb.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y)
        end
    end)
    orb.MouseButton1Click:Connect(function()
        if moved then return end
        main.Visible = not main.Visible
        orb.Text = main.Visible and "×" or "◆"
    end)
    close.MouseButton1Click:Connect(function()
        main.Visible = false
        orb.Text = "◆"
    end)

    tabs["Dashboard"].MouseButton1Click:Fire()
    stat("Final Clean carregado: Dashboard organizada.")
end



--========================================================
-- BOSS FARM FINAL FIX
-- Corrige boss farm não matando:
-- 1. Procura boss por lista BOSS_NAMES.
-- 2. Usa root/humanoid deep.
-- 3. Move até o boss.
-- 4. Ataca com remote e tool.
--========================================================

function OnyxFindRootDeep(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    return obj:FindFirstChild("HumanoidRootPart", true)
        or obj:FindFirstChild("UpperTorso", true)
        or obj:FindFirstChild("Torso", true)
        or obj.PrimaryPart
        or obj:FindFirstChildWhichIsA("BasePart", true)
end

function OnyxFindHumanoidDeep(obj)
    if not obj then return nil end
    return obj:FindFirstChildOfClass("Humanoid") or obj:FindFirstChildWhichIsA("Humanoid", true)
end

function OnyxIsBossAlive(obj)
    if not obj or not obj.Parent then return false end
    local hum = OnyxFindHumanoidDeep(obj)
    local root = OnyxFindRootDeep(obj)
    return hum and root and hum.Health > 0
end

function OnyxGetClosestAnyBoss()
    local root = getRootSafe() or getRoot()
    if not root then return nil end

    local best = nil
    local bestDist = math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local isBoss = false

            if BOSS_NAMES and BOSS_NAMES[obj.Name] then
                isBoss = true
            end

            local lower = string.lower(obj.Name)
            if string.find(lower, "boss", 1, true)
                or string.find(lower, "aizen", 1, true)
                or string.find(lower, "sukuna", 1, true)
                or string.find(lower, "gojo", 1, true)
                or string.find(lower, "saber", 1, true)
                or string.find(lower, "rimuru", 1, true)
                or string.find(lower, "raiden", 1, true)
                or string.find(lower, "stone", 1, true)
                or string.find(lower, "jinwoo", 1, true)
                or string.find(lower, "verdant", 1, true)
            then
                isBoss = true
            end

            if isBoss and OnyxIsBossAlive(obj) then
                local br = OnyxFindRootDeep(obj)
                local dist = (br.Position - root.Position).Magnitude

                if dist < bestDist then
                    bestDist = dist
                    best = obj
                end
            end
        end
    end

    return best
end

function OnyxAttackOnce()
    if actionRemote then
        pcall(function()
            actionRemote:FireServer("M1", "Combat")
        end)
    end

    local char = player.Character
    local tool = char and char:FindFirstChildOfClass("Tool")
    if tool then
        pcall(function()
            tool:Activate()
        end)
    end
end

function startAutoFarmBoss()
    if autoFarmBossEnabled then return end

    autoFarmBossEnabled = true
    bossThread = bossThread + 1
    local myThread = bossThread

    if autoFarmBossButton then
        autoFarmBossButton.Text = "Boss: ON"
        autoFarmBossButton.BackgroundColor3 = Color3.fromRGB(28, 220, 135)
    end

    task.spawn(function()
        while autoFarmBossEnabled and myThread == bossThread do
            local ok, err = pcall(function()
                local target = selectedBoss

                if not OnyxIsBossAlive(target) then
                    target = OnyxGetClosestAnyBoss()
                    selectedBoss = target
                end

                if target and OnyxIsBossAlive(target) then
                    local br = OnyxFindRootDeep(target)

                    if br then
                        smoothMoveTo(getFarmCFrame(br, getHeight(bossHeightBox, 30)))
                        OnyxAttackOnce()

                        if bossDropdown and bossDropdown.Button then
                            bossDropdown.Button.Text = "Select Boss: " .. target.Name .. " ▼"
                        end

                        if bossSelectedLabel then
                            bossSelectedLabel.Text = "Boss selected: " .. target.Name
                        end

                        if setStatus then
                            setStatus("Killing boss: " .. target.Name)
                        end
                    end
                else
                    if setStatus then
                        setStatus("Waiting for boss")
                    end
                    task.wait(0.5)
                end
            end)

            if not ok then
                selectedBoss = nil
                warn("[BossFarmFix]", err)
                if setStatus then
                    setStatus("Boss farm recovered")
                end
                task.wait(0.8)
            end

            task.wait(0.12)
        end
    end)
end

function stopAutoFarmBoss()
    autoFarmBossEnabled = false
    bossThread = bossThread + 1

    if autoFarmBossButton then
        autoFarmBossButton.Text = "Boss: OFF"
        autoFarmBossButton.BackgroundColor3 = Color3.fromRGB(220, 155, 65)
    end

    if not autoFarmNPCEnabled and not autoDungeonEnabled then
        clearSmoothHold()
    end
end

