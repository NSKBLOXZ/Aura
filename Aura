function findTool(namePart)
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")

    if not namePart or namePart == "" then
        if character then
            local equipped = character:FindFirstChildOfClass("Tool")
            if equipped then
                return equipped
            end
        end
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    return tool
                end
            end
        end
        return nil
    end

    local needle = string.lower(namePart)
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and string.find(string.lower(tool.Name), needle, 1, true) then
                return tool
            end
        end
    end
    if character then
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") and string.find(string.lower(tool.Name), needle, 1, true) then
                return tool
            end
        end
    end
    return nil
end

function equipTool(namePart)
    local tool = findTool(namePart)
    if tool and tool.Parent ~= player.Character then
        getHumanoid():EquipTool(tool)
        return true
    end
    return tool ~= nil
end

function getBosses()
    buildMobCache()
    local bosses = {}
    for i = #bossCache, 1, -1 do
        local boss = bossCache[i]
        if isAlive(boss) then
            table.insert(bosses, boss)
        else
            table.remove(bossCache, i)
        end
    end
    table.sort(bosses, function(a, b)
        return a.Name < b.Name
    end)
    return bosses
end


function getPriorityTargetPart(model)
    if not model or not model.Parent then
        return nil
    end

    if model:IsA("BasePart") then
        return model
    end

    if model:IsA("Model") then
        return model:FindFirstChild("HumanoidRootPart")
            or model.PrimaryPart
            or model:FindFirstChildWhichIsA("BasePart", true)
    end

    return nil
end

function isPriorityTargetAlive(model)
    if not model or not model.Parent then
        return false
    end

    local part = getPriorityTargetPart(model)
    if not part then
        return false
    end

    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum then
        return hum.Health > 0
    end

    return true
end

function getClosestPriorityTarget()
    local root = getRootSafe()
    if not root then
        return nil
    end

    local best = nil
    local bestDist = math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and BOSS_NAMES[obj.Name] and isPriorityTargetAlive(obj) then
            local part = getPriorityTargetPart(obj)
            if part then
                local dist = (part.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = obj
                end
            end
        end
    end

    return best
end

