local function refreshBossList()
	clearButtons(bossListFrame)
	local bosses = getBosses(true)

	if #bosses == 0 then
		createListButton(bossListFrame, "Nenhum boss encontrado", function() end)
		selectedBoss = nil
		bossSelectedLabel.Text = "Boss selecionado: nenhum"
	else
		for _, boss in ipairs(bosses) do
			createListButton(bossListFrame, boss.Name, function()
				selectedBoss = boss
				bossSelectedLabel.Text = "Boss selecionado: " .. boss.Name
				setStatus("Status: boss selecionado")
			end)
		end

		if not selectedBoss or not isAliveModel(selectedBoss) then
			selectedBoss = bosses[1]
			bossSelectedLabel.Text = "Boss selecionado: " .. selectedBoss.Name
		end
	end

	updateScrollCanvas(bossListFrame, bossListLayout)
end

local function refreshNPCList()
	clearButtons(npcListFrame)
	local available = getAvailableNPCNames(true)

	if #available == 0 then
		createListButton(npcListFrame, "Nenhum NPC encontrado", function() end)
		selectedNPCName = nil
		npcSelectedLabel.Text = "NPC selecionado: nenhum"
	else
		for _, npcName in ipairs(available) do
			createListButton(npcListFrame, npcName, function()
				selectedNPCName = npcName
				npcSelectedLabel.Text = "NPC selecionado: " .. npcName
				setStatus("Status: npc selecionado")
			end)
		end

		if not selectedNPCName then
			selectedNPCName = available[1]
			npcSelectedLabel.Text = "NPC selecionado: " .. selectedNPCName
		end
	end

	updateScrollCanvas(npcListFrame, npcListLayout)
end

local dragging = false
local dragStart = nil
local startPos = nil

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if input.KeyCode == guiToggleKey then
		frame.Visible = not frame.Visible
	end
end)

