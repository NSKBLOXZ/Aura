function setupDragControls()
    local draggingFrame = false
    local frameDragStart = nil
    local frameStartPos = nil
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingFrame = true
            frameDragStart = input.Position
            frameStartPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End or input.UserInputState == Enum.UserInputState.Cancel then
                    draggingFrame = false
                    savedFramePosition = frame.Position
                    if saveConfig then saveConfig() end
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if draggingFrame and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - frameDragStart
            frame.Position = UDim2.new(frameStartPos.X.Scale, frameStartPos.X.Offset + delta.X, frameStartPos.Y.Scale, frameStartPos.Y.Offset + delta.Y)
        end
    end)
    local draggingToggle = false
    local toggleDragStart = nil
    local toggleStartPos = nil
    local toggleMoved = false
    toggleButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingToggle = true
            toggleMoved = false
            toggleDragStart = input.Position
            toggleStartPos = toggleButton.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End or input.UserInputState == Enum.UserInputState.Cancel then
                    draggingToggle = false
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if draggingToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - toggleDragStart
            if math.abs(delta.X) > 3 or math.abs(delta.Y) > 3 then
                toggleMoved = true
            end
            toggleButton.Position = UDim2.new(toggleStartPos.X.Scale, toggleStartPos.X.Offset + delta.X, toggleStartPos.Y.Scale, toggleStartPos.Y.Offset + delta.Y)
        end
    end)
    toggleButton.MouseButton1Click:Connect(function()
        if toggleMoved then
            toggleMoved = false
            return
        end
        setGuiVisible(not frame.Visible)
    end)
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == guiToggleKey then
            setGuiVisible(not frame.Visible)
        end
    end)
end



