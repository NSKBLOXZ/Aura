function getClosestBoss()
    buildMobCache()
    local root = getRoot()
    local best = nil
    local bestDist = math.huge

    for i = #bossCache, 1, -1 do
        local boss = bossCache[i]
        if isAlive(boss) then
            local hrp = boss:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = boss
                end
            end
        else
            table.remove(bossCache, i)
        end
    end

    return best
end


function findHumanoidDeep(model)
    if not model then return nil end
    return model:FindFirstChildOfClass("Humanoid") or model:FindFirstChildWhichIsA("Humanoid", true)
end

function findRootDeep(model)
    if not model then return nil end
    if model:IsA("BasePart") then return model end

    return model:FindFirstChild("HumanoidRootPart", true)
        or model:FindFirstChild("UpperTorso", true)
        or model:FindFirstChild("Torso", true)
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart", true)
end

function getClosestIchigoBankai()
    local root = getRootSafe() or getRoot()
    if not root then return nil end

    local best = nil
    local bestDist = math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and string.find(string.lower(obj.Name), "ichigo", 1, true) then
            local hum = findHumanoidDeep(obj)
            local hrp = findRootDeep(obj)

            if hum and hrp and hum.Health > 0 then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = obj
                end
            end
        end
    end

    return best
end


function getClosestNPCByName(name)
    if not name or name == "" then
        return nil
    end

    if string.find(string.lower(tostring(name)), "ichigo", 1, true) then
        local ichigo = getClosestIchigoBankai()
        if ichigo then
            return ichigo
        end
    end

    buildMobCache()

    local root = getRoot()
    local list = npcCache[name]
    local best = nil
    local bestDist = math.huge

    if not list then
        return nil
    end

    for i = #list, 1, -1 do
        local obj = list[i]
        if isAlive(obj) and obj.Name == name then
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = obj
                end
            end
        else
            table.remove(list, i)
        end
    end

    return best
end

