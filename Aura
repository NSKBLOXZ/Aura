	task.spawn(function()
		while autoFarmNPCEnabled and myThread == autoFarmNPCThread do
			if not selectedNPCName or selectedNPCName == "" then
				setStatus("Status: npc inválido")
				task.wait(0.5)
				continue
			end

			local targetNPC = getClosestAliveNPCByName(selectedNPCName)

			if not targetNPC then
				setStatus("Status: esperando npc " .. selectedNPCName)
				task.wait(0.25)
				continue
			end

			local hrp = targetNPC:FindFirstChild("HumanoidRootPart")
			if hrp then
				local targetPos = hrp.Position + Vector3.new(0, getHeight(npcHeightBox, 20), 0)
				getRoot().CFrame = CFrame.new(targetPos)
				setStatus("Status: farmando " .. targetNPC.Name)
			end

			task.wait(0.08)
		end
	end)
end)

