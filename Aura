local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getRoot()
	local character = getCharacter()
	return character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart")
end

local function getHumanoid()
	local character = getCharacter()
	return character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid")
end

local function getHeight(box, defaultValue)
	local n = tonumber(box.Text)
	if not n then
		return defaultValue
	end
	return math.clamp(n, 5, 300)
end

local function isAliveModel(model)
	if not model or not model.Parent then
		return false
	end
	local hum = model:FindFirstChildOfClass("Humanoid")
	local hrp = model:FindFirstChild("HumanoidRootPart")
	return hum and hrp and hum.Health > 0
end

local function parseKeyCode(text)
	if not text or text == "" then
		return nil
	end

	local cleaned = string.gsub(text, "%s+", "")
	local ok, result = pcall(function()
		return Enum.KeyCode[cleaned]
	end)

	if ok then
		return result
	end

	return nil
end

local function findToolByNamePart(namePart)
	if namePart == "" then
		return nil
	end

	local needle = string.lower(namePart)

	local backpack = player:FindFirstChild("Backpack")
	if backpack then
		for _, tool in ipairs(backpack:GetChildren()) do
			if tool:IsA("Tool") and string.find(string.lower(tool.Name), needle, 1, true) then
				return tool
			end
		end
	end

	local character = player.Character
	if character then
		for _, tool in ipairs(character:GetChildren()) do
			if tool:IsA("Tool") and string.find(string.lower(tool.Name), needle, 1, true) then
				return tool
			end
		end
	end

	return nil
end

local function equipToolByNamePart(namePart)
	local tool = findToolByNamePart(namePart)
	if not tool then
		return false
	end

	if tool.Parent ~= player.Character then
		getHumanoid():EquipTool(tool)
	end

	return true
end

local function rebuildBossCache()
	cachedBosses = {}

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and BOSS_NAMES[obj.Name] and isAliveModel(obj) then
			table.insert(cachedBosses, obj)
		end
	end

	table.sort(cachedBosses, function(a, b)
		return a.Name < b.Name
	end)

	lastBossCacheTime = os.clock()
end

local function getBosses(forceRefresh)
	if forceRefresh or os.clock() - lastBossCacheTime > 1.5 then
		rebuildBossCache()
	end

	local alive = {}
	for _, boss in ipairs(cachedBosses) do
		if isAliveModel(boss) then
			table.insert(alive, boss)
		end
	end
	return alive
end

local function getClosestAliveBoss()
	local root = getRoot()
	local bestBoss = nil
	local bestDist = math.huge

	for _, boss in ipairs(getBosses(false)) do
		local hrp = boss:FindFirstChild("HumanoidRootPart")
		if hrp then
			local dist = (hrp.Position - root.Position).Magnitude
			if dist < bestDist then
				bestDist = dist
				bestBoss = boss
			end
		end
	end

	return bestBoss
end

local function rebuildNPCCache()
	cachedNPCModels = {}

	for _, name in ipairs(NPC_NAMES) do
		cachedNPCModels[name] = {}
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and isAliveModel(obj) and cachedNPCModels[obj.Name] then
			table.insert(cachedNPCModels[obj.Name], obj)
		end
	end

	lastNPCCacheTime = os.clock()
end

local function getAvailableNPCNames(forceRefresh)
	if forceRefresh or os.clock() - lastNPCCacheTime > 1.5 then
		rebuildNPCCache()
	end

	local ordered = {}

	for _, npcName in ipairs(NPC_NAMES) do
		local foundAlive = false
		local list = cachedNPCModels[npcName]

		if list then
			for _, npc in ipairs(list) do
				if isAliveModel(npc) then
					foundAlive = true
					break
				end
			end
		end

		if foundAlive then
			table.insert(ordered, npcName)
		end
	end

	return ordered
end

local function getClosestAliveNPCByName(npcName)
	if not npcName or npcName == "" then
		return nil
	end

	if os.clock() - lastNPCCacheTime > 1.5 then
		rebuildNPCCache()
	end

	local root = getRoot()
	local closest = nil
	local closestDistance = math.huge
	local list = cachedNPCModels[npcName] or {}

	for _, npc in ipairs(list) do
		if isAliveModel(npc) then
			local hrp = npc:FindFirstChild("HumanoidRootPart")
			if hrp then
				local distance = (hrp.Position - root.Position).Magnitude
				if distance < closestDistance then
					closestDistance = distance
					closest = npc
				end
			end
		end
	end

	return closest
end

