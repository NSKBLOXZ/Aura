local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end
local function getRoot()
    local character = getCharacter()
    return character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart")
end
local function getHumanoid()
    local character = getCharacter()
    return character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid")
end

local function isAlive(model)
    if not model or not model.Parent then
        return false
    end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")
    return hum ~= nil and root ~= nil and hum.Health > 0
end

local function getHeight(box, defaultValue)
    local value = tonumber(box.Text)
    if value then
        return math.clamp(value, 5, 300)
    end
    return defaultValue
end

local function disableNoClip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
end

local function enableNoClip()
    disableNoClip()
    noclipConnection = RunService.Stepped:Connect(function()
        local character = player.Character
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function setFarmMode(mode)
    farmMode = mode or "Above"
    if farmMode == "Below" then
        enableNoClip()
    else
        disableNoClip()
    end
end

local function getFarmCFrame(targetRoot, height)
    height = height or 20
    if farmMode == "Above" then
        return CFrame.new(targetRoot.Position + Vector3.new(0, height, 0), targetRoot.Position)
    elseif farmMode == "Behind" then
        local pos = targetRoot.Position - (targetRoot.CFrame.LookVector * height) + Vector3.new(0, 2, 0)
        return CFrame.new(pos, targetRoot.Position)
    elseif farmMode == "Below" then
        return CFrame.new(targetRoot.Position - Vector3.new(0, height, 0), targetRoot.Position)
    end
    return CFrame.new(targetRoot.Position + Vector3.new(0, height, 0), targetRoot.Position)
end

local function setupSmoothHold()
    local root = getRoot()
    if not bodyPosition or bodyPosition.Parent ~= root then
        if bodyPosition then
            bodyPosition:Destroy()
        end
        bodyPosition = Instance.new("BodyPosition")
        bodyPosition.Name = "FarmSmoothPosition"
        bodyPosition.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        bodyPosition.P = 25000
        bodyPosition.D = 1200
        bodyPosition.Position = root.Position
        bodyPosition.Parent = root
    end
    if not bodyGyro or bodyGyro.Parent ~= root then
        if bodyGyro then
            bodyGyro:Destroy()
        end
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.Name = "FarmSmoothGyro"
        bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        bodyGyro.P = 25000
        bodyGyro.D = 800
        bodyGyro.CFrame = root.CFrame
        bodyGyro.Parent = root
    end
end

local function smoothMoveTo(cframe)
    setupSmoothHold()
    bodyPosition.Position = cframe.Position
    bodyGyro.CFrame = cframe
end

local function clearSmoothHold()
    if bodyPosition then
        bodyPosition:Destroy()
        bodyPosition = nil
    end
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
end

local function findTool(namePart)
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")

    if not namePart or namePart == "" then
        if character then
            local equipped = character:FindFirstChildOfClass("Tool")
            if equipped then
                return equipped
            end
        end
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    return tool
                end
            end
        end
        return nil
    end

    local needle = string.lower(namePart)
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and string.find(string.lower(tool.Name), needle, 1, true) then
                return tool
            end
        end
    end
    if character then
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") and string.find(string.lower(tool.Name), needle, 1, true) then
                return tool
            end
        end
    end
    return nil
end

local function equipTool(namePart)
    local tool = findTool(namePart)
    if tool and tool.Parent ~= player.Character then
        getHumanoid():EquipTool(tool)
        return true
    end
    return tool ~= nil
end

local function getBosses()
    local bosses = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and BOSS_NAMES[obj.Name] and isAlive(obj) then
            table.insert(bosses, obj)
        end
    end
    table.sort(bosses, function(a, b)
        return a.Name < b.Name
    end)
    return bosses
end

local function getClosestBoss()
    local root = getRoot()
    local best = nil
    local bestDist = math.huge
    for _, boss in ipairs(getBosses()) do
        local hrp = boss:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dist = (hrp.Position - root.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                best = boss
            end
        end
    end
    return best
end

local function getClosestNPCByName(name)
    if not name or name == "" then
        return nil
    end
    local root = getRoot()
    local best = nil
    local bestDist = math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == name and isAlive(obj) then
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = obj
                end
            end
        end
    end
    return best
end

