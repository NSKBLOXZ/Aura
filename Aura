    aizenSummonThread = aizenSummonThread + 1
    updateAizenSummonButton()
    clearSmoothHold()
end

function startAizenSummonFarm()
    if autoAizenSummonEnabled then return end

    autoAizenSummonEnabled = true
    aizenHollowKills = 0
    aizenTargetHollow = nil
    aizenTrackedHumanoids = {}
    aizenSummonThread = aizenSummonThread + 1
    local myThread = aizenSummonThread

    -- Deixa o ciclo controlar o farm: Hollow -> Summon -> Boss -> repetir.
    stopAutoFarmNPC()
    updateAizenSummonButton()

    task.spawn(function()
        while autoAizenSummonEnabled and myThread == aizenSummonThread do
            local ok, err = pcall(function()
                local root = getRootSafe()
                if not root then
                    setStatus("Aizen cycle waiting respawn")
                    task.wait(0.6)
                    return
                end

                -- Se já tiver boss vivo, mantém o Auto Farm Boss ligado junto.
                local livingBoss = selectedBoss
                if not livingBoss or not isAlive(livingBoss) then
                    livingBoss = getClosestBoss()
                    selectedBoss = livingBoss
                end

                if livingBoss and isAlive(livingBoss) then
                    if not autoFarmBossEnabled then
                        startAutoFarmBoss()
                    end
                    setStatus("Auto Aizen: farming boss " .. livingBoss.Name)
                    task.wait(0.5)
                    return
                end

                -- Se não tem boss vivo e o Auto Boss ficou ligado, desliga para voltar aos Hollows.
                if autoFarmBossEnabled then
                    stopAutoFarmBoss()
                end

                -- Ao chegar em 50 Hollows, usa o AizenSummonNPC e liga o Auto Farm Boss.
                if aizenHollowKills >= 50 then
                    setStatus("50 Hollows done, spawning Aizen")
                    local summoned = tryActivateAizenSummon()
                    task.wait(summoned and 2 or 1)

                    selectedBoss = getClosestBoss()
                    if selectedBoss and isAlive(selectedBoss) then
                        startAutoFarmBoss()
                        setStatus("Aizen spawned, Auto Boss ON")
                    else
                        setStatus("Aizen spawned/waiting for boss")
                    end

                    -- Zera para o próximo ciclo, mas NÃO desliga o botão.
                    aizenHollowKills = 0
                    aizenTargetHollow = nil
                    aizenTrackedHumanoids = {}
                    updateAizenSummonButton()
                    task.wait(0.8)
                    return
                end

                -- Farm dos Hollows até 50.
                if not aizenTargetHollow or not isAlive(aizenTargetHollow) or aizenTargetHollow.Name ~= "Hollow" then
                    aizenTargetHollow = getClosestNPCByName("Hollow")
                    if aizenTargetHollow then
                        trackAizenHollowDeath(aizenTargetHollow)
                    end
                end

                if aizenTargetHollow then
                    local hrp = aizenTargetHollow:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        smoothMoveTo(getFarmCFrame(hrp, getHeight(npcHeightBox, 20)))
                        setStatus("Aizen cycle Hollow: " .. tostring(aizenHollowKills) .. "/50")
                    else
                        aizenTargetHollow = nil
                    end
                else
                    setStatus("Waiting for Hollow")
                    task.wait(0.5)
                end

                if actionRemote then
                    pcall(function()
                        actionRemote:FireServer("M1", "Combat")
                    end)
                end

                local char = player.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
                if tool then
                    pcall(function()
                        tool:Activate()
                    end)
                end
            end)

            if not ok then
                aizenTargetHollow = nil
                setStatus("Aizen cycle recovered after error")
                warn("Aizen cycle recovered:", err)
                task.wait(0.7)
            end

            task.wait(0.12)
        end
    end)
end

