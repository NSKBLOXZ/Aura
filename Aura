function corner(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 10)
    c.Parent = obj
    return c
end

function stroke(obj, color, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(110, 180, 255)
    s.Transparency = transparency or 0.55
    s.Thickness = 1
    s.Parent = obj
    return s
end

function padding(obj, left, right, top, bottom)
    local p = Instance.new("UIPadding")
    p.PaddingLeft = UDim.new(0, left or 0)
    p.PaddingRight = UDim.new(0, right or left or 0)
    p.PaddingTop = UDim.new(0, top or 0)
    p.PaddingBottom = UDim.new(0, bottom or top or 0)
    p.Parent = obj
    return p
end


function addGradient(obj, color1, color2)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color1 or Color3.fromRGB(40, 220, 140)),
        ColorSequenceKeypoint.new(1, color2 or Color3.fromRGB(30, 200, 130))
    })
    g.Rotation = 25
    g.Parent = obj
    return g
end

function makeLabel(parent, text, size, color)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color or Color3.fromRGB(240, 248, 255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = size or (isMobile and 11 or 13)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Size = UDim2.new(1, 0, 0, 20)
    label.ZIndex = 20
    label.Parent = parent
    return label
end

function makeButton(parent, text, color, height)
