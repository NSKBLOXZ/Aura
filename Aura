local function setGuiVisible(value)
    frame.Visible = value
    toggleButton.Text = value and "×" or "≡"
end
local function setActiveTab(tab)
    pageBoss.Visible = tab == "boss"
    pageNPC.Visible = tab == "npc"
    pagePriority.Visible = tab == "priority"
    pageTeleport.Visible = tab == "teleport"
    pageConfig.Visible = tab == "config"

    tabBoss.BackgroundColor3 = tab == "boss" and Color3.fromRGB(45, 100, 200) or Color3.fromRGB(25, 34, 52)
    tabNPC.BackgroundColor3 = tab == "npc" and Color3.fromRGB(45, 100, 200) or Color3.fromRGB(25, 34, 52)
    tabPriority.BackgroundColor3 = tab == "priority" and Color3.fromRGB(45, 100, 200) or Color3.fromRGB(25, 34, 52)
    tabTeleport.BackgroundColor3 = tab == "teleport" and Color3.fromRGB(45, 100, 200) or Color3.fromRGB(25, 34, 52)
    tabConfig.BackgroundColor3 = tab == "config" and Color3.fromRGB(45, 100, 200) or Color3.fromRGB(25, 34, 52)

    if tab == "boss" then titleText.Text = "Farm Hub - Boss" end
    if tab == "npc" then titleText.Text = "Farm Hub - NPC" end
    if tab == "priority" then titleText.Text = "Farm Hub - Priority" end
    if tab == "teleport" then titleText.Text = "Farm Hub - Teleport" end
    if tab == "config" then titleText.Text = "Farm Hub - Config" end
end
local function refreshBossList()
    local bosses = getBosses()
    local names = {}
    for _, boss in ipairs(bosses) do
        table.insert(names, boss.Name)
    end
    if #names == 0 then
        names = {"None"}
    end
    bossDropdown.Refresh(names)
    if #bosses > 0 then
        selectedBoss = bosses[1]
        bossDropdown.Button.Text = "Select Boss: " .. selectedBoss.Name .. " ▼"
        bossSelectedLabel.Text = "Boss selected: " .. selectedBoss.Name
    else
        selectedBoss = nil
        bossDropdown.Button.Text = "Select Boss: None ▼"
        bossSelectedLabel.Text = "Boss selected: none"
    end
end
local function refreshNPCList()
    npcDropdown.Refresh(NPC_NAMES)
    npcDropdown.Button.Text = "Select NPC: " .. tostring(selectedNPCName) .. " ▼"
    npcSelectedLabel.Text = "NPC selected: " .. tostring(selectedNPCName)
end
local function stopAutoFarmBoss()
    autoFarmBossEnabled = false
    bossThread = bossThread + 1
    autoFarmBossButton.Text = "Boss: OFF"
    autoFarmBossButton.BackgroundColor3 = Color3.fromRGB(180, 115, 36)
    if not autoFarmNPCEnabled then clearSmoothHold() end
end
local function stopAutoFarmNPC()
    autoFarmNPCEnabled = false
    npcThread = npcThread + 1
    autoFarmNPCButton.Text = "NPC: OFF"
    autoFarmNPCButton.BackgroundColor3 = Color3.fromRGB(180, 115, 36)
    if not autoFarmBossEnabled then clearSmoothHold() end
end
local function stopAutoAttack()
    autoAttackEnabled = false
    attackThread = attackThread + 1
    autoAttackButton.Text = "Attack: OFF"
    autoAttackButton.BackgroundColor3 = Color3.fromRGB(170, 70, 70)
end
local function stopAutoEquip()
    autoEquipEnabled = false
    equipThread = equipThread + 1
    autoEquipButton.Text = "Auto Equip: OFF"
    autoEquipButton.BackgroundColor3 = Color3.fromRGB(65, 135, 85)
end
local function stopPriority()
    priorityEnabled = false
    priorityThread = priorityThread + 1
end
local function startAutoFarmBoss()
    if autoFarmBossEnabled then return end
    autoFarmBossEnabled = true
    bossThread = bossThread + 1
    local myThread = bossThread
    autoFarmBossButton.Text = "Boss: ON"
    autoFarmBossButton.BackgroundColor3 = Color3.fromRGB(45, 150, 80)
    task.spawn(function()
        while autoFarmBossEnabled and myThread == bossThread do
            if not selectedBoss or not isAlive(selectedBoss) then
                selectedBoss = getClosestBoss()
                if not selectedBoss then
                    setStatus("Waiting for boss")
                    task.wait(0.5)
                    continue
                end
                bossDropdown.Button.Text = "Select Boss: " .. selectedBoss.Name .. " ▼"
                bossSelectedLabel.Text = "Boss selected: " .. selectedBoss.Name
            end
            local hrp = selectedBoss:FindFirstChild("HumanoidRootPart")
            if hrp then
                smoothMoveTo(getFarmCFrame(hrp, getHeight(bossHeightBox, 30)))
                setStatus("Farming boss: " .. selectedBoss.Name)
            end
            task.wait(0.12)
        end
    end)
end
local function startAutoFarmNPC()
    if autoFarmNPCEnabled then return end
    if not selectedNPCName then selectedNPCName = NPC_NAMES[1] end
    autoFarmNPCEnabled = true
    npcThread = npcThread + 1
    local myThread = npcThread
    autoFarmNPCButton.Text = "NPC: ON"
    autoFarmNPCButton.BackgroundColor3 = Color3.fromRGB(45, 150, 80)
    task.spawn(function()
        while autoFarmNPCEnabled and myThread == npcThread do
            local npc = getClosestNPCByName(selectedNPCName)
            if npc then
                local hrp = npc:FindFirstChild("HumanoidRootPart")
                if hrp then
                    smoothMoveTo(getFarmCFrame(hrp, getHeight(npcHeightBox, 20)))
                    setStatus("Farming NPC: " .. npc.Name)
                end
            else
                setStatus("Waiting for NPC: " .. tostring(selectedNPCName))
            end
            task.wait(0.12)
        end
    end)
end
local actionRemote = nil
pcall(function()
    local rs = game:GetService("ReplicatedStorage")
    local packages = rs:FindFirstChild("Packages")
    local index = packages and packages:FindFirstChild("_Index")
    local netPackage = index and index:FindFirstChild("sleitnick_net@0.2.0")
    local net = netPackage and netPackage:FindFirstChild("net")
    actionRemote = net and net:FindFirstChild("RE/ActionRemote")
end)
local function startAutoAttack()
    if autoAttackEnabled then return end
    autoAttackEnabled = true
    attackThread = attackThread + 1
    local myThread = attackThread
    autoAttackButton.Text = "Attack: ON"
    autoAttackButton.BackgroundColor3 = Color3.fromRGB(45, 150, 80)
    task.spawn(function()
        while autoAttackEnabled and myThread == attackThread do
            if actionRemote then
                pcall(function() actionRemote:FireServer("M1", "Combat") end)
            end
            local char = player.Character
            local tool = char and char:FindFirstChildOfClass("Tool")
            if tool then
                pcall(function() tool:Activate() end)
            end
            task.wait(0.12)
        end
    end)
end
local function startAutoEquip()
    if autoEquipEnabled then return end
    autoEquipEnabled = true
    equipThread = equipThread + 1
    local myThread = equipThread
    autoEquipButton.Text = "Auto Equip: ON"
    autoEquipButton.BackgroundColor3 = Color3.fromRGB(45, 150, 80)
    task.spawn(function()
        while autoEquipEnabled and myThread == equipThread do
            equipTool(equipBox.Text or "")
            task.wait(0.8)
        end
    end)
end
