function getClosestBoss()
    buildMobCache()
    local root = getRoot()
    local best = nil
    local bestDist = math.huge

    for i = #bossCache, 1, -1 do
        local boss = bossCache[i]
        if isAlive(boss) then
            local hrp = boss:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = boss
                end
            end
        else
            table.remove(bossCache, i)
        end
    end

    return best
end

function getClosestNPCByName(name)
    if not name or name == "" then
        return nil
    end

    buildMobCache()

    local root = getRoot()
    local list = npcCache[name]
    local best = nil
    local bestDist = math.huge

    if not list then
        return nil
    end

    for i = #list, 1, -1 do
        local obj = list[i]
        if isAlive(obj) and obj.Name == name then
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = obj
                end
            end
        else
            table.remove(list, i)
        end
    end

    return best
end

