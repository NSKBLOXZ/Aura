        manualNoClip = manualNoClipEnabled,
        speed = speedValue
    }
end

function saveConfig()
    if writefile then
        local success, encoded = pcall(function()
            return HttpService:JSONEncode(getConfigData())
        end)

        if success then
            writefile(CONFIG_FILE, encoded)
            setStatus("Config saved")
        else
            setStatus("Config save failed")
        end
    else
        setStatus("writefile not supported")
    end
end

function loadConfig()
    if not (isfile and readfile and isfile(CONFIG_FILE)) then
        setStatus("No config file")
        return
    end

    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)

    if not success or type(data) ~= "table" then
        setStatus("Config load failed")
        return
    end

    if data.guiKey and Enum.KeyCode[data.guiKey] then
        guiToggleKey = Enum.KeyCode[data.guiKey]
        keyBox.Text = data.guiKey
    end

    if data.farmMode then
        setFarmMode(data.farmMode)
        farmModeDropdown.Button.Text = "Farm Mode: " .. data.farmMode .. " ▼"
    end

    if data.bossDistance then
        bossHeightBox.Text = tostring(data.bossDistance)
    end

    if data.npcDistance then
        npcHeightBox.Text = tostring(data.npcDistance)
    end

    if data.dungeonDistance then
        dungeonHeightBox.Text = tostring(data.dungeonDistance)
    end

    if data.weapon then
        equipBox.Text = tostring(data.weapon)
    end

    if data.autoExecuteUrl then
        autoExecuteUrlBox.Text = tostring(data.autoExecuteUrl)
    end

    autoExecuteEnabled = data.autoExecute == true
    compactModeEnabled = data.compactMode == true
    savedFramePosition = decodeUDim2(data.framePosition)
    if data.speed then
        local loadedSpeed = tonumber(data.speed)
        if loadedSpeed then
            speedValue = math.clamp(loadedSpeed, 16, 200)
        end
    end

    manualNoClipEnabled = data.manualNoClip == true
    applySpeed()
    setManualNoClip(manualNoClipEnabled)

    updateAutoExecuteButton()
    updateCompactModeButton()
    updateMovementButtons()
    applyGuiLayout(true)

    if data.theme and THEMES[data.theme] then
        applyTheme(data.theme)
    else
        applyTheme(currentTheme)
    end

    setStatus("Config loaded")
end

