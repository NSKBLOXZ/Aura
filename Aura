function getCharacter()
    while true do
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local root = character and character:FindFirstChild("HumanoidRootPart")

        if character and character.Parent and humanoid and humanoid.Health > 0 and root then
            return character
        end

        task.wait(0.2)
    end
end

function getRoot()
    local character = getCharacter()
    return character:FindFirstChild("HumanoidRootPart")
end

function getHumanoid()
    local character = getCharacter()
    return character:FindFirstChildOfClass("Humanoid")
end

function getRootSafe()
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local root = character and character:FindFirstChild("HumanoidRootPart")

    if character and character.Parent and humanoid and humanoid.Health > 0 and root then
        return root
    end

    return nil
end

function isAlive(model)
    if not model or not model.Parent then
        return false
    end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")
    return hum ~= nil and root ~= nil and hum.Health > 0
end

function getHeight(box, defaultValue)
    local value = tonumber(box.Text)
    if value then
        return math.clamp(value, 5, 300)
    end
    return defaultValue
end

function disableNoClip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
end

function enableNoClip()
    disableNoClip()
    noclipConnection = RunService.Stepped:Connect(function()
        local character = player.Character
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

function setFarmMode(mode)
    farmMode = mode or "Above"
    if farmMode == "Below" then
        enableNoClip()
    else
        disableNoClip()
    end
end

function getFarmCFrame(targetRoot, height)
    height = height or 20
    if farmMode == "Above" then
        return CFrame.new(targetRoot.Position + Vector3.new(0, height, 0), targetRoot.Position)
    elseif farmMode == "Behind" then
        local pos = targetRoot.Position - (targetRoot.CFrame.LookVector * height) + Vector3.new(0, 2, 0)
        return CFrame.new(pos, targetRoot.Position)
    elseif farmMode == "Below" then
        return CFrame.new(targetRoot.Position - Vector3.new(0, height, 0), targetRoot.Position)
    end
    return CFrame.new(targetRoot.Position + Vector3.new(0, height, 0), targetRoot.Position)
end

function setupSmoothHold()
    local root = getRoot()
    if not bodyPosition or bodyPosition.Parent ~= root then
        if bodyPosition then
            bodyPosition:Destroy()
        end
        bodyPosition = Instance.new("BodyPosition")
        bodyPosition.Name = "FarmSmoothPosition"
        bodyPosition.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        bodyPosition.P = 25000
        bodyPosition.D = 1200
        bodyPosition.Position = root.Position
        bodyPosition.Parent = root
    end
    if not bodyGyro or bodyGyro.Parent ~= root then
        if bodyGyro then
            bodyGyro:Destroy()
        end
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.Name = "FarmSmoothGyro"
        bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        bodyGyro.P = 25000
        bodyGyro.D = 800
        bodyGyro.CFrame = root.CFrame
        bodyGyro.Parent = root
    end
end

