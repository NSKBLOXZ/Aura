aboveBossButton.MouseButton1Click:Connect(function()
	stopFollowBoss()
	stopAutoFarmBoss()

	if not selectedBoss or not isAliveModel(selectedBoss) then
		setStatus("Status: boss morto ou não selecionado")
		return
	end

	followBossEnabled = true
	followBossThread += 1
	local myThread = followBossThread

	task.spawn(function()
		while followBossEnabled and myThread == followBossThread do
			if not selectedBoss or not isAliveModel(selectedBoss) then
				setStatus("Status: boss morreu")
				break
			end

			local bossRoot = selectedBoss:FindFirstChild("HumanoidRootPart")
			if not bossRoot then
				setStatus("Status: HRP do boss sumiu")
				break
			end

			local targetPos = bossRoot.Position + Vector3.new(0, getHeight(heightBox, 30), 0)
			getRoot().CFrame = CFrame.new(targetPos)
			task.wait(0.08)
		end

		followBossEnabled = false
	end)

	setStatus("Status: acima do boss")
end)

autoFarmBossButton.MouseButton1Click:Connect(function()
	if autoFarmBossEnabled then
		stopAutoFarmBoss()
		setStatus("Status: auto farm boss desligado")
		return
	end

	stopFollowBoss()
	stopFly()

	autoFarmBossEnabled = true
	autoFarmBossThread += 1
	local myThread = autoFarmBossThread
	autoFarmBossButton.Text = "Auto Farm Boss: ON"

	task.spawn(function()
		while autoFarmBossEnabled and myThread == autoFarmBossThread do
			if not selectedBoss or not isAliveModel(selectedBoss) then
				selectedBoss = getClosestAliveBoss()
				if selectedBoss then
					bossSelectedLabel.Text = "Boss selecionado: " .. selectedBoss.Name
				else
					setStatus("Status: esperando boss vivo")
					task.wait(0.6)
					continue
				end
			end

			local hrp = selectedBoss:FindFirstChild("HumanoidRootPart")
			if hrp then
				local targetPos = hrp.Position + Vector3.new(0, getHeight(heightBox, 30), 0)
				getRoot().CFrame = CFrame.new(targetPos)
				setStatus("Status: auto farm boss em " .. selectedBoss.Name)
			end

			task.wait(0.08)
		end
	end)
end)

