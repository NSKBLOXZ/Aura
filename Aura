function tryActivateAizenSummon()
    local summon = workspace:FindFirstChild("AizenSummonNPC", true)
    if not summon then
        setStatus("AizenSummonNPC not found")
        return false
    end

    local root = getRootSafe()
    local summonPart = nil

    if summon:IsA("BasePart") then
        summonPart = summon
    elseif summon:IsA("Model") then
        summonPart = summon:FindFirstChild("HumanoidRootPart") or summon.PrimaryPart or summon:FindFirstChildWhichIsA("BasePart", true)
    else
        summonPart = summon:FindFirstAncestorWhichIsA("BasePart")
    end

    if summonPart and root then
        clearSmoothHold()
        root.CFrame = summonPart.CFrame + Vector3.new(0, 4, 0)
        task.wait(0.25)
    end

    local activated = false

    for _, obj in ipairs(summon:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            pcall(function()
                fireproximityprompt(obj)
                activated = true
            end)
        elseif obj:IsA("ClickDetector") then
            pcall(function()
                fireclickdetector(obj)
                activated = true
            end)
        end
    end

    -- Caso o prompt esteja no pai do modelo/parte.
    local parent = summon.Parent
    if parent then
        for _, obj in ipairs(parent:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and tostring(obj.Parent):find("Aizen") then
                pcall(function()
                    fireproximityprompt(obj)
                    activated = true
                end)
            elseif obj:IsA("ClickDetector") and tostring(obj.Parent):find("Aizen") then
                pcall(function()
                    fireclickdetector(obj)
                    activated = true
                end)
            end
        end
    end

    if activated then
        setStatus("Aizen summon activated")
    else
        setStatus("Go near AizenSummonNPC / no prompt found")
    end

    return activated
end

function trackAizenHollowDeath(hollow)
    if not hollow then return end
    local hum = hollow:FindFirstChildOfClass("Humanoid")
    if not hum or aizenTrackedHumanoids[hum] then return end

    aizenTrackedHumanoids[hum] = true
    hum.Died:Connect(function()
        if autoAizenSummonEnabled then
            aizenHollowKills = math.clamp(aizenHollowKills + 1, 0, 50)
            updateAizenSummonButton()
            setStatus("Aizen Hollows: " .. tostring(aizenHollowKills) .. "/50")
        end
    end)
end

function stopAizenSummonFarm()
    autoAizenSummonEnabled = false
