function startAutoDungeon()
    if autoDungeonEnabled then return end
    autoDungeonEnabled = true
    dungeonThread = dungeonThread + 1
    local myThread = dungeonThread

    autoDungeonButton.Text = "Auto Dungeon: ON"
    autoDungeonButton.BackgroundColor3 = Color3.fromRGB(40, 220, 140)

    task.spawn(function()
        while autoDungeonEnabled and myThread == dungeonThread do
            local ok, err = pcall(function()
                local root = getRootSafe()
                if not root then
                    currentDungeonNPC = nil
                    bodyPosition = nil
                    bodyGyro = nil
                    setStatus("Auto Dungeon waiting respawn")
                    task.wait(0.6)
                    return
                end

                if not currentDungeonNPC or not isAlive(currentDungeonNPC) or not DUNGEON_NPC_NAME_SET[currentDungeonNPC.Name] then
                    currentDungeonNPC = getClosestDungeonNPC()
                end

                if selectedDungeon == "Tower" then
                    local boss = getClosestBoss()

                    if boss and isAlive(boss) then
                        local bossRoot = boss:FindFirstChild("HumanoidRootPart")

                        if bossRoot then
                            smoothMoveTo(getFarmCFrame(bossRoot, getHeight(dungeonHeightBox, 20)))
                            setStatus("Tower Boss: " .. boss.Name)
                        end
                    elseif currentDungeonNPC then
                        local hrp = currentDungeonNPC:FindFirstChild("HumanoidRootPart")

                        if hrp then
                            smoothMoveTo(getFarmCFrame(hrp, getHeight(dungeonHeightBox, 20)))
                            setStatus("Tower NPC: " .. currentDungeonNPC.Name)
                        else
                            currentDungeonNPC = nil
                        end
                    else
                        setStatus("Waiting for Tower enemies")
                        task.wait(0.5)
                    end
                else
                    if currentDungeonNPC then
                        local hrp = currentDungeonNPC:FindFirstChild("HumanoidRootPart")

                        if hrp then
                            smoothMoveTo(getFarmCFrame(hrp, getHeight(dungeonHeightBox, 20)))
                            setStatus("Auto Dungeon: " .. currentDungeonNPC.Name)
                        else
                            currentDungeonNPC = nil
                        end
                    else
                        refreshDungeonCache()
                        currentDungeonNPC = getClosestDungeonNPC()

                        if currentDungeonNPC then
                            local hrp = currentDungeonNPC:FindFirstChild("HumanoidRootPart")

                            if hrp then
                                smoothMoveTo(getFarmCFrame(hrp, getHeight(dungeonHeightBox, 20)))
                                setStatus("Auto Dungeon: " .. currentDungeonNPC.Name)
                            end
                        else
                            setStatus("Waiting for dungeon NPC")
                            task.wait(0.5)
                        end
                    end
                end

                if actionRemote then
                    pcall(function()
                        actionRemote:FireServer("M1", "Combat")
                    end)
                end

                local char = player.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
                if tool then
                    pcall(function()
                        tool:Activate()
                    end)
                end
            end)

            if not ok then
                currentDungeonNPC = nil
                bodyPosition = nil
                bodyGyro = nil
                setStatus("Auto Dungeon recovered after error")
                warn("Auto Dungeon recovered:", err)
                task.wait(0.7)
            end

            task.wait(0.12)
        end
    end)
end

